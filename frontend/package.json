{
  "name": "musicvid-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n ui,api,comfyui -c cyan,green,yellow \"vite\" \"cd ../backend && venv/Scripts/uvicorn main:app --reload --port 8000\" \"cd ../comfyui && venv/Scripts/python main.py --port 8289 --listen 127.0.0.1 --disable-metadata --dont-print-server\"",
    "dev:ui": "vite",
    "dev:api": "cd ../backend && venv/Scripts/uvicorn main:app --reload --port 8000",
    "dev:comfyui": "cd ../comfyui && venv/Scripts/python main.py --port 8289 --listen 127.0.0.1 --disable-metadata --dont-print-server",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "uuid": "^14.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
