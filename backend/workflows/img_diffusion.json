{
  "_note": "Full pipeline — fp8/fp16 Z-Image UNet + LTX 2.3 img2vid with custom audio conditioning. Nodes 1-11: Z-Image txt2img -> character frame. Nodes 12-35: LTX 2.3 img2vid + audio encode -> clip MP4. All {{PLACEHOLDER}} strings replaced by comfyui.py before submission.",

  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name":    "{{ZIMG_UNET_NAME}}",
      "weight_dtype": "{{ZIMG_WEIGHT_DTYPE}}"
    }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "{{ZIMG_CLIP_NAME}}",
      "type":      "lumina2"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{ZIMG_VAE_NAME}}"
    }
  },
  "4": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model":          ["1", 0],
      "lora_name":      "{{LORA_NAME}}",
      "strength_model": "{{LORA_STRENGTH}}"
    }
  },
  "5": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": ["4", 0],
      "shift": 3.0
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "{{POSITIVE_PROMPT}}"
    }
  },
  "7": {
    "class_type": "ConditioningZeroOut",
    "inputs": {
      "conditioning": ["6", 0]
    }
  },
  "8": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width":      "{{WIDTH}}",
      "height":     "{{HEIGHT}}",
      "batch_size": 1
    }
  },
  "10": {
    "class_type": "KSampler",
    "inputs": {
      "model":        ["5", 0],
      "positive":     ["6", 0],
      "negative":     ["7", 0],
      "latent_image": ["8", 0],
      "seed":         "{{SEED}}",
      "steps":        9,
      "cfg":          1.0,
      "sampler_name": "res_multistep",
      "scheduler":    "simple",
      "denoise":      1.0
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae":     ["3", 0]
    }
  },

  "12": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name":    "{{LTX_UNET_NAME}}",
      "weight_dtype": "{{LTX_WEIGHT_DTYPE}}"
    }
  },
  "13": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model":          ["12", 0],
      "lora_name":      "{{LTX_DISTILL_LORA_NAME}}",
      "strength_model": "{{LTX_DISTILL_LORA_STRENGTH}}"
    }
  },
  "14": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "{{LTX_CLIP_NAME1}}",
      "clip_name2": "{{LTX_CLIP_NAME2}}",
      "type":       "ltxv"
    }
  },
  "15": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{LTX_VIDEO_VAE_NAME}}"
    }
  },
  "16": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{LTX_AUDIO_VAE_NAME}}"
    }
  },
  "17": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": "{{POSITIVE_PROMPT}}"
    }
  },
  "18": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": "{{LTX_NEGATIVE_PROMPT}}"
    }
  },
  "19": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive":   ["17", 0],
      "negative":   ["18", 0],
      "frame_rate": "{{FPS}}"
    }
  },
  "20": {
    "class_type": "LTXVPreprocess",
    "inputs": {
      "image":           ["11", 0],
      "img_compression": 33
    }
  },
  "21": {
    "class_type": "EmptyLTXVLatentVideo",
    "inputs": {
      "width":      "{{WIDTH}}",
      "height":     "{{HEIGHT}}",
      "length":     "{{NUM_FRAMES}}",
      "batch_size": 1
    }
  },
  "22": {
    "class_type": "LTXVImgToVideoInplace",
    "inputs": {
      "vae":      ["15", 0],
      "image":    ["20", 0],
      "latent":   ["21", 0],
      "strength": 1.0,
      "bypass":   false
    }
  },
  "23": {
    "class_type": "LoadAudio",
    "inputs": {
      "audio": "{{AUDIO_FILENAME}}"
    }
  },
  "24": {
    "class_type": "TrimAudioDuration",
    "inputs": {
      "audio":       ["23", 0],
      "start_index": "{{SEGMENT_START}}",
      "duration":    "{{SEGMENT_DURATION}}"
    }
  },
  "25": {
    "class_type": "LTXVAudioVAEEncode",
    "inputs": {
      "audio":     ["24", 0],
      "audio_vae": ["16", 0]
    }
  },
  "26": {
    "class_type": "LTXVConcatAVLatent",
    "inputs": {
      "video_latent": ["22", 0],
      "audio_latent": ["25", 0]
    }
  },
  "27": {
    "class_type": "CFGGuider",
    "inputs": {
      "model":    ["13", 0],
      "positive": ["19", 0],
      "negative": ["19", 1],
      "cfg":      1.0
    }
  },
  "28": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "latent":     ["26", 0],
      "steps":      8,
      "max_shift":  2.05,
      "base_shift": 0.95,
      "stretch":    true,
      "terminal":   0.1
    }
  },
  "29": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler_cfg_pp"
    }
  },
  "30": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": "{{SEED}}"
    }
  },
  "31": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise":        ["30", 0],
      "guider":       ["27", 0],
      "sampler":      ["29", 0],
      "sigmas":       ["28", 0],
      "latent_image": ["26", 0]
    }
  },
  "32": {
    "class_type": "LTXVSeparateAVLatent",
    "inputs": {
      "av_latent": ["31", 0]
    }
  },
  "33": {
    "class_type": "VAEDecodeTiled",
    "inputs": {
      "samples":          ["32", 0],
      "vae":              ["15", 0],
      "tile_size":        512,
      "overlap":          64,
      "temporal_size":    4096,
      "temporal_overlap": 8
    }
  },
  "34": {
    "class_type": "LTXVAudioVAEDecode",
    "inputs": {
      "samples":   ["32", 1],
      "audio_vae": ["16", 0]
    }
  },
  "35": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images":          ["33", 0],
      "audio":           ["34", 0],
      "frame_rate":      "{{FPS}}",
      "loop_count":      0,
      "filename_prefix": "{{JOB_ID}}",
      "format":          "video/h264-mp4",
      "pix_fmt":         "yuv420p",
      "crf":             19,
      "save_metadata":   false,
      "pingpong":        false,
      "save_output":     true,
      "trim_to_audio":   false
    }
  }
}
